; Parser/* byte-arithmetic leaves — kernel/forms/helpers/parser-bytes.form
;
; The nineteen absolute leaves under the parser's helper graph.
; Each is a pure function over byte vectors and integer offsets,
; typically 2-5 instructions of IL. After this batch, the entire
; parser graph (parser.form → parser-primitives.form → this
; file → IL opcodes) has every slot encoded, and
; S-07/parse_form is operationally complete from top to bottom.
;
; This is the first helper chain in the seed where every slot
; is encoded end-to-end. It is the proof of concept that the
; v0.2.0-helpers cadence works: orchestration, then primitives,
; then leaves, then everything runs.
;
; Synthesis chain:
;   provocation:  parser-primitives.form references these
;                 nineteen slots but none are bound. Without
;                 this batch, the parser chain is three layers
;                 deep but still has pending CALLs at its
;                 bottom.
;   grounding:    A0.6, A1.2, A6.1 — code is substance, type
;                 is intrinsic, bytes are content-addressed
;   approach:     each leaf is either a structural call into
;                 the Schema/* primitives (which themselves
;                 are pending, but that indirection is
;                 acknowledged in the audit) or a direct
;                 arithmetic operation over an Ident value
;   composes_with: S-03/ROOT_RO, Schema/* (eventually)
;
; All nineteen leaves qualify for the helper exemption (each
; is well under the 30-instruction smallness threshold). No
; individual proof artifacts; verified inline as part of
; parser.proof when written.

; ============================================================
; Parser/bytes_starts_with — does `bytes` begin with `prefix`?
; ============================================================

(form
  :type-tag      "Form/v1"
  :name          "bytes_starts_with"
  :declared-caps (S-03/ROOT_RO)
  :declared-traps ()
  :arity         2
  :locals-n      3
  :code (
    STORE   0                       ; prefix
    STORE   1                       ; bytes
    LOAD    1
    PUSH    0
    LOAD    0
    PUSH    "Bytes/len"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=1
    STORE   2
    LOAD    2
    PUSH    "Schema/bytes_in_range"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=3                ; → candidate prefix bytes
    LOAD    0
    EQ
    RET
  )
  :rationale-hash $$BLAKE3$$/parser-bytes-rationale
)

; ============================================================
; Parser/cursor_offset — project the Nat from Pair{Bytes, Nat}
; ============================================================

(form
  :type-tag      "Form/v1"
  :name          "cursor_offset"
  :declared-caps (S-03/ROOT_RO)
  :declared-traps (ETYPE)
  :arity         1
  :locals-n      1
  :code (
    STORE   0
    LOAD    0
    READ
    SND
    RET
  )
  :rationale-hash $$BLAKE3$$/parser-bytes-rationale
)

; ============================================================
; Parser/cursor_bytes — project the Bytes from a Cursor
;
; Not in STUBS.md but needed as a shared helper by several of
; the other leaves. Catalogued in STUBS.md in the same commit
; so the inventory stays honest.
; ============================================================

(form
  :type-tag      "Form/v1"
  :name          "cursor_bytes"
  :declared-caps (S-03/ROOT_RO)
  :declared-traps (ETYPE)
  :arity         1
  :locals-n      1
  :code (
    STORE   0
    LOAD    0
    READ
    FST
    RET
  )
  :rationale-hash $$BLAKE3$$/parser-bytes-rationale
)

; ============================================================
; Parser/byte_at — read byte at offset
; ============================================================

(form
  :type-tag      "Form/v1"
  :name          "byte_at"
  :declared-caps (S-03/ROOT_RO)
  :declared-traps (ETYPE)
  :arity         2
  :locals-n      2
  :code (
    STORE   0                       ; offset
    STORE   1                       ; bytes
    LOAD    1
    LOAD    0
    PUSH    1
    PUSH    "Schema/bytes_in_range"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=3                ; → single-byte Bytes
    RET
  )
  :rationale-hash $$BLAKE3$$/parser-bytes-rationale
)

; ============================================================
; Parser/cursor_byte_is — does the byte at the cursor equal X?
; ============================================================

(form
  :type-tag      "Form/v1"
  :name          "cursor_byte_is"
  :declared-caps (S-03/ROOT_RO)
  :declared-traps (ETYPE)
  :arity         2
  :locals-n      3
  :code (
    STORE   0                       ; expected byte
    STORE   1                       ; cursor
    LOAD    1
    PUSH    "Parser/cursor_bytes"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=1
    STORE   2
    LOAD    1
    PUSH    "Parser/cursor_offset"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=1
    LOAD    2
    PUSH    "Parser/byte_at"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=2                ; order: (bytes, offset) via SWAP semantics
    LOAD    0
    EQ
    RET
  )
  :rationale-hash $$BLAKE3$$/parser-bytes-rationale
)

; ============================================================
; Parser/cursor_starts_with — does the cursor's suffix begin with prefix?
; ============================================================

(form
  :type-tag      "Form/v1"
  :name          "cursor_starts_with"
  :declared-caps (S-03/ROOT_RO)
  :declared-traps (ETYPE)
  :arity         2
  :locals-n      4
  :code (
    STORE   0                       ; prefix
    STORE   1                       ; cursor
    LOAD    1
    PUSH    "Parser/cursor_bytes"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=1
    STORE   2
    LOAD    1
    PUSH    "Parser/cursor_offset"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=1
    STORE   3
    LOAD    2
    LOAD    3
    LOAD    0
    PUSH    "Bytes/len"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=1
    PUSH    "Schema/bytes_in_range"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=3
    LOAD    0
    EQ
    RET
  )
  :rationale-hash $$BLAKE3$$/parser-bytes-rationale
)

; ============================================================
; Parser/cursor_advance — produce a new cursor with offset += n
; ============================================================

(form
  :type-tag      "Form/v1"
  :name          "cursor_advance"
  :declared-caps (S-03/ROOT_RO)
  :declared-traps (ETYPE)
  :arity         2
  :locals-n      3
  :code (
    STORE   0                       ; n
    STORE   1                       ; cursor
    LOAD    1
    PUSH    "Parser/cursor_bytes"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=1
    STORE   2
    LOAD    1
    PUSH    "Parser/cursor_offset"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=1
    LOAD    0
    ADD
    LOAD    2
    SWAP
    MAKEPAIR
    SEAL    Cursor
    RET
  )
  :rationale-hash $$BLAKE3$$/parser-bytes-rationale
)

