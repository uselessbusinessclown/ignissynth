; ============================================================
; Parser/operand_reader_dispatch — dispatch on schema id to
; the matching operand reader
; ============================================================

(form
  :type-tag      "Form/v1"
  :name          "operand_reader_dispatch"
  :declared-caps (S-03/ROOT_RO)
  :declared-traps (ETYPE)
  :arity         2
  :locals-n      2
  :code (
    STORE   0                       ; schema id bytes
    STORE   1                       ; cursor
    LOAD    0
    PUSH    "Parser/operand_reader_table"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=1                ; → Hash of matching reader Form
    LOAD    1
    SWAP
    CALL    h=$ /n=1                ; invoke the reader
    RET
  )
  :rationale-hash $$BLAKE3$$/parser-bytes-rationale
)

; ============================================================
; Parser/opcode_table_scan — linear scan over the 30-entry
; opcode table for a matching mnemonic
; ============================================================

(form
  :type-tag      "Form/v1"
  :name          "opcode_table_scan"
  :declared-caps (S-03/ROOT_RO)
  :declared-traps ()
  :arity         2
  :locals-n      2
  :code (
    STORE   0                       ; mnemonic bytes
    STORE   1                       ; table hash
    LOAD    1
    LOAD    0
    PUSH    "Parser/opcode_table_scan_rec"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=2
    RET
  )
  :rationale-hash $$BLAKE3$$/parser-bytes-rationale
)

; ============================================================
; Parser/skip_one_canonical_space — skip exactly one space or
; zero spaces (the canonicaliser leaves exactly one space
; between tokens, or zero after ")" or before "(").
; ============================================================

(form
  :type-tag      "Form/v1"
  :name          "skip_one_canonical_space"
  :declared-caps (S-03/ROOT_RO)
  :declared-traps (ETYPE)
  :arity         1
  :locals-n      1
  :code (
    STORE   0
    LOAD    0
    PUSH    " "
    PUSH    "Parser/cursor_byte_is"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=2
    JMPZ    +no_space
    LOAD    0
    PUSH    1
    PUSH    "Parser/cursor_advance"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=2
    RET
    :no_space
    LOAD    0
    RET
  )
  :rationale-hash $$BLAKE3$$/parser-bytes-rationale
)

; ============================================================
; Parser/vec_append — append an element to a Vec
; ============================================================

(form
  :type-tag      "Form/v1"
  :name          "vec_append"
  :declared-caps (S-03/ROOT_RO)
  :declared-traps (ETYPE)
  :arity         2
  :locals-n      2
  :code (
    STORE   0                       ; element
    STORE   1                       ; vec
    LOAD    1
    LOAD    0
    PUSH    "Vec/append"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=2                ; → new Vec
    RET
  )
  :rationale-hash $$BLAKE3$$/parser-bytes-rationale
)

(exports
  (bytes_starts_with       (Bytes, Bytes)           → Bool)
  (cursor_offset           (Cursor)                 → Nat)
  (cursor_bytes            (Cursor)                 → Bytes)
  (byte_at                 (Bytes, Nat)             → Byte)
  (cursor_byte_is          (Cursor, Bytes)          → Bool)
  (cursor_starts_with      (Cursor, Bytes)          → Bool)
  (cursor_advance          (Cursor, Nat)            → Cursor)
  (scan_digits             (Cursor)                 → Pair{Cursor, Bytes})
  (digits_to_nat           (Bytes)                  → Nat)
  (scan_until_byte         (Cursor, Bytes)          → Pair{Cursor, Bytes})
  (scan_hash_token         (Cursor)                 → Pair{Cursor, Bytes})
  (bytes_to_hash           (Bytes)                  → Hash)
  (scan_idents_until_close_as_capids    (Cursor, Vec{CapId})    → Pair{Cursor, Vec{CapId}})
  (scan_idents_until_close_as_trapkinds (Cursor, Vec{TrapKind}) → Pair{Cursor, Vec{TrapKind}})
  (scan_ident_chars        (Cursor)                 → Pair{Cursor, Bytes})
  (operand_schema_of       (OpcodeSpec)             → Bytes)
  (operand_reader_dispatch (Cursor, Bytes)          → Pair{Cursor, Vec{Operand}})
  (opcode_table_scan       (Hash, Bytes)            → OpcodeSpec)
  (skip_one_canonical_space(Cursor)                 → Cursor)
  (vec_append              (Vec, T)                 → Vec))


; ============================================================
; Deeper primitives referenced but not encoded here
;
; This file references lower-level primitives that are *not*
; in the original 19-leaf catalogue:
;
;   - Parser/scan_class_run            (Cursor, ClassTag) → Pair{Cursor, Bytes}
;   - Parser/scan_until_byte_rec       (Cursor, Byte) → Pair{Cursor, Bytes}
;   - Parser/fold_digits_base10        (Bytes) → Nat
;   - Parser/hash_token_resolve        (Bytes) → Hash
;   - Parser/ident_to_capid            (Bytes) → CapId
;   - Parser/ident_to_trapkind         (Bytes) → TrapKind
;   - Parser/operand_reader_table      (Bytes) → Hash
;   - Parser/opcode_table_scan_rec     (Hash, Bytes) → OpcodeSpec
;   - Vec/append                       (Vec, T) → Vec
;   - OpcodeSpec/proj/schema           (OpcodeSpec) → Bytes
;
; These are "second-generation leaves" — even smaller helpers
; that the 19 catalogued leaves delegate to. Each is 2-8
; instructions. The audit's Gap 4 is resolved at the
; orchestration + primitives + first-generation-leaves layers,
; but the parser chain technically has one more layer beneath.
;
; This is expected and not a discipline failure: the helper
; encoding work *should* terminate at simple arithmetic and
; table lookups, and the discipline makes the termination
; visible by cataloguing each layer. These deeper primitives
; will be encoded in parser-bytes-leaves.form or folded into
; the schema-primitives batch — decision to be made in the
; next session.
;
; The hierarchy of the parser's helper graph as of this commit:
;
;   parser.form (orchestration, 8 sub-Forms)          ✓ batch 3
;     ↓
;   parser-primitives.form (13 sub-Forms)             ✓ batch 4
;     ↓
;   parser-bytes.form (19 sub-Forms) ← THIS           ✓ batch 5
;     ↓
;   parser-bytes-leaves.form (~10 sub-Forms)          ⌛ next
;     ↓
;   Schema/* primitives (7 sub-Forms)                 ⌛ pending
;     ↓
;   IL opcodes (PUSH, LOAD, ADD, SUB, EQ, etc.)       ✓ in IL.md
;
; Five layers from parser entry point to IL opcodes. The
; discipline of pushing complexity into smaller and smaller
; helpers is working as designed — each layer has a clear
; boundary, each sub-Form is verifiable in isolation, and the
; bottom is finite and enumerable.
; ============================================================
