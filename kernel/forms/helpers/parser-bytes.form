  :name          "operand_schema_of"
  :declared-caps (S-03/ROOT_RO)
  :declared-traps (ETYPE)
  :arity         1
  :locals-n      1
  :code (
    STORE   0
    LOAD    0
    READ
    PUSH    "OpcodeSpec/proj/schema"
