; ============================================================
; Parser/scan_idents_until_close_as_capids
;
; Recursive helper that scans a sequence of identifiers
; separated by canonical whitespace, terminated by ")".
; ============================================================

(form
  :type-tag      "Form/v1"
  :name          "scan_idents_until_close_as_capids"
  :declared-caps (S-03/ROOT_RO)
  :declared-traps (ETYPE)
  :arity         2
  :locals-n      4
  :code (
    STORE   0                       ; accumulator Vec{CapId}
    STORE   1                       ; cursor
    LOAD    1
    PUSH    "Parser/skip_one_canonical_space"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=1
    STORE   1
    LOAD    1
    PUSH    ")"
    PUSH    "Parser/cursor_byte_is"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=2
    JMPZ    +not_close
    LOAD    1
    PUSH    1
    PUSH    "Parser/cursor_advance"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=2
    LOAD    0
    MAKEPAIR
    RET
    :not_close
    LOAD    1
    PUSH    "Parser/read_identifier"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=1
    STORE   2
    LOAD    0
    LOAD    2
    SND
    PUSH    "Parser/ident_to_capid"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=1
    PUSH    "Parser/vec_append"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=2
    STORE   3
    LOAD    2
    FST
    LOAD    3
    PUSH    "Parser/scan_idents_until_close_as_capids"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=2
    RET
  )
  :rationale-hash $$BLAKE3$$/parser-bytes-rationale
)

; ============================================================
; Parser/scan_idents_until_close_as_trapkinds
; Same shape but validates each ident against the TrapKind
; enumeration.
; ============================================================

(form
  :type-tag      "Form/v1"
  :name          "scan_idents_until_close_as_trapkinds"
  :declared-caps (S-03/ROOT_RO)
  :declared-traps (ETYPE)
  :arity         2
  :locals-n      4
  :code (
    STORE   0
    STORE   1
    LOAD    1
    PUSH    "Parser/skip_one_canonical_space"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=1
    STORE   1
    LOAD    1
    PUSH    ")"
    PUSH    "Parser/cursor_byte_is"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=2
    JMPZ    +not_close
    LOAD    1
    PUSH    1
    PUSH    "Parser/cursor_advance"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=2
    LOAD    0
    MAKEPAIR
    RET
    :not_close
    LOAD    1
    PUSH    "Parser/read_identifier"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=1
    STORE   2
    LOAD    2
    SND
    PUSH    "Parser/ident_to_trapkind"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=1                ; traps ETYPE if not in enumeration
    STORE   3
    LOAD    0
    LOAD    3
    PUSH    "Parser/vec_append"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=2
    STORE   3
    LOAD    2
    FST
    LOAD    3
    PUSH    "Parser/scan_idents_until_close_as_trapkinds"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=2
    RET
  )
  :rationale-hash $$BLAKE3$$/parser-bytes-rationale
)

