; ============================================================
; S-04/vec/len — length of a sealed Vec
;
; The only non-projection helper in this file. Used by
; S-04/append's grounding-non-empty check (lines ~62-68 of
; S-04-weave-log.form). Bound here because it shares the
; "tiny pure helper, S-03/ROOT_RO only" shape with the
; projections.
; ============================================================

(form
  :type-tag      "Form/v1"
  :name          "vec_len"
  :declared-caps (S-03/ROOT_RO)
  :declared-traps (ETYPE)
  :arity         1
  :locals-n      2
  :code (
    STORE   0                   ; vec hash
    LOAD    0
    READ                        ; → sealed vec bytes
    STORE   1
    LOAD    1
    PUSH    "Vec/len"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=1            ; → Nat via the vec layout helper
    RET
  )
  :rationale-hash $$BLAKE3$$/s04-projections-rationale
)

; ============================================================
; S-04/bytes/len — length of a sealed byte vector
