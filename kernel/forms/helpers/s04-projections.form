  :rationale-hash $$BLAKE3$$/s04-projections-rationale
)

(exports
  (proj_prev      (Hash) → Hash)
  (proj_kind      (Hash) → EntryKind)
  (proj_grounding (Hash) → Vec{AxiomId})
  (proj_rationale (Hash) → Hash)
  (proj_outputs   (Hash) → Vec{Hash})
  (vec_len        (Hash) → Nat)
  (bytes_len      (Hash) → Nat))

; ============================================================
; Notes on the schema-helper indirection
;
; Each projection delegates to a "Entry/proj/{field}" or
; "Vec/len" or "Bytes/len" sub-helper that knows the byte
; layout of the named substance type. This indirection is
; deliberate:
;
;   - The byte layout of Entry, Vec, and Bytes is part of the
;     substance type system, not part of S-04. Putting it in
;     a sub-helper means changing the layout doesn't require
;     re-synthesizing every projection.
;
;   - The sub-helpers are themselves tiny Forms (one READ +
;     one byte-offset arithmetic + one structural cast each)
;     and will be encoded in a sibling helper file as part of
;     v0.2.0-helpers.
;
;   - The proof artifacts that cite these projections compose
;     against the schema helpers' obligations transitively;
;     each schema helper's body is a one-line structural lemma.
;
; Until the schema helpers are encoded, these projection
; bodies have a pending leaf at the inner CALL. STUBS.md will
; be updated to catalogue the schema helpers as a separate
; v0.2.0 batch.
; ============================================================
