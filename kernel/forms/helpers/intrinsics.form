; Third-generation kernel intrinsics — kernel/forms/helpers/intrinsics.form
;
; The absolute bottom of the helper graph. These 18 Forms are
; pure functions over the IL's primitive value types: Bytes,
; Nat, Vec, and the parser's lowest-level recursion helpers.
; Every sub-Form in this file is 3-15 instructions of IL;
; all qualify for the helper exemption.
;
; These intrinsics are named by the substance type they operate
; on (Bytes/*, Nat/*, Vec/*) or by their role in the parser's
; recursive descent (Parser/*). They are the leaves that the
; five helper layers above them ultimately delegate to:
;
;   parser.form              (orchestration)
;     ↓
;   parser-primitives.form   (13 sub-Forms)
;     ↓
;   parser-bytes.form        (20 sub-Forms)
;     ↓
;   primitives.form          (17 sub-Forms)
;     ↓
;   intrinsics.form          ← THIS (18 sub-Forms)
;     ↓
;   IL opcodes               (PUSH, LOAD, ADD, SUB, EQ, …)
;
; After this batch the parser's transitive helper closure is
; complete: every slot reachable from parser.form is bound.
;
; Synthesis chain:
;   provocation:  primitives.form catalogued 18 third-generation
;                 leaves as "pending — intrinsics". This file
;                 encodes them.
;   grounding:    A0.5 (energy is finite; leaves must be
;                 finite), A1.2 (type is intrinsic), A1.3
;                 (sealing is permanent), A6.1 (code is
;                 substance)
;   approach:     one Form per intrinsic; grouped by substance
;                 type; recursive helpers use explicit acc
;                 parameters with a tail-call CALL pattern so
;                 the IL's bounded-step semantics hold.
;
; All 18 qualify for the helper exemption (none exceeds ~20
; instructions after unrolling the comment structure). No
; individual proof artifacts are required.

; ============================================================
; Group A: Bytes/* intrinsics
; ============================================================

; ------------------------------------------------------------
; Bytes/len — return the length (Nat) of a Bytes substance.
;
; Layout from kernel/types/SCHEMA.md:
;   offset 0  : type_tag ("Bytes/v1", 8 bytes)
;   offset 8  : n        (Nat, 8 bytes)
;   offset 16 : bytes    (n bytes)
;
; We read the substance, verify the type tag, then extract the
; 8-byte Nat at offset 8 with to_nat_be.
; ------------------------------------------------------------

(form
  :type-tag      "Form/v1"
  :name          "Bytes_len"
  :declared-caps (S-03/ROOT_RO)
  :declared-traps (ETYPE)
  :arity         1
  :locals-n      2
  :code (
    STORE   0                       ; Bytes hash
    LOAD    0
    READ                            ; → raw bytes
    STORE   1
    LOAD    1
    PUSH    0
    PUSH    8
    PUSH    "Schema/bytes_in_range"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=3                ; → type_tag slice (8 bytes)
    PUSH    "Bytes/v1"
    EQ
    JMPZ    +type_ok
    TRAP    ETYPE
    :type_ok
    LOAD    1
    PUSH    8
    PUSH    8
    PUSH    "Schema/bytes_in_range"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=3                ; → 8-byte length field
    PUSH    "Bytes/to_nat_be"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=1                ; → Nat
    RET
  )
  :rationale-hash $$BLAKE3$$/intrinsics-rationale
)

; ------------------------------------------------------------
; Bytes/slice — extract a sub-sequence of bytes.
;
; Signature: (bytes: Bytes, offset: Nat, length: Nat) → Bytes
;
; Reads the raw byte vector (offset 16 in the Bytes substance),
; skips `offset` bytes, then takes `length` bytes. Returns a
; new sealed Bytes substance.
; ------------------------------------------------------------

(form
  :type-tag      "Form/v1"
  :name          "Bytes_slice"
  :declared-caps (S-03/ROOT_RO S-03/ROOT_RW)
  :declared-traps (ETYPE)
  :arity         3
  :locals-n      5
  :code (
    STORE   0                       ; length
    STORE   1                       ; offset
    STORE   2                       ; Bytes hash
    LOAD    2
    READ                            ; → raw substance bytes
    STORE   3
    ; verify type tag
    LOAD    3
    PUSH    0
    PUSH    8
    PUSH    "Schema/bytes_in_range"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=3
    PUSH    "Bytes/v1"
    EQ
    JMPZ    +type_ok
    TRAP    ETYPE
    :type_ok
    ; payload starts at offset 16
    LOAD    3
    LOAD    1
    PUSH    16
    ADD                             ; absolute offset = 16 + caller offset
    LOAD    0
    PUSH    "Schema/bytes_in_range"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=3                ; → raw slice bytes
    STORE   4
    ; seal the slice as a new Bytes substance
    LOAD    0                       ; length prefix
    LOAD    4                       ; payload
    MAKEPAIR
    SEAL    "Bytes/v1"
    RET
  )
  :rationale-hash $$BLAKE3$$/intrinsics-rationale
)

; ------------------------------------------------------------
; Bytes/to_nat_be — interpret a big-endian byte sequence as Nat.
;
; Signature: (bytes: Bytes) → Nat
;
; Tail-recursive fold: reads each byte, shifts accumulator
; left by 8, ORs in the byte. Delegates to the inner rec helper
; Bytes/to_nat_be_rec.
; ------------------------------------------------------------

(form
  :type-tag      "Form/v1"
  :name          "Bytes_to_nat_be"
  :declared-caps (S-03/ROOT_RO)
  :declared-traps (ETYPE)
  :arity         1
  :locals-n      1
  :code (
    STORE   0
    LOAD    0
    PUSH    0                       ; initial accumulator
    PUSH    0                       ; initial index
    PUSH    "Bytes/to_nat_be_rec"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=3
    RET
  )
  :rationale-hash $$BLAKE3$$/intrinsics-rationale
)

; ------------------------------------------------------------
; Bytes/to_nat_be_rec — inner accumulator for Bytes/to_nat_be.
;
; Signature: (bytes: Bytes, acc: Nat, idx: Nat) → Nat
;
; Base case: idx == Bytes/len(bytes) → return acc.
; Step: acc' = acc * 256 + byte_at(bytes, idx); recurse idx+1.
; ------------------------------------------------------------

(form
  :type-tag      "Form/v1"
  :name          "Bytes_to_nat_be_rec"
  :declared-caps (S-03/ROOT_RO)
  :declared-traps (ETYPE)
  :arity         3
  :locals-n      5
  :code (
    STORE   0                       ; idx
    STORE   1                       ; acc
    STORE   2                       ; bytes
    ; base case: idx == len?
    LOAD    2
    PUSH    "Bytes/len"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=1
    LOAD    0
    EQ
    JMPZ    +not_done
    LOAD    1
    RET
    :not_done
    ; acc' = acc * 256 + byte_at(bytes, idx)
    LOAD    1
    PUSH    256
    PUSH    "Nat/mul"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=2
    LOAD    2
    LOAD    0
    PUSH    "Parser/byte_at"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=2                ; → single-byte Bytes
    PUSH    "Bytes/to_nat_be"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=1                ; → Nat value of byte
    ADD
    STORE   3                       ; new acc
    LOAD    0
    PUSH    1
    ADD
    STORE   4                       ; idx + 1
    LOAD    2
    LOAD    3
    LOAD    4
    PUSH    "Bytes/to_nat_be_rec"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=3
    RET
  )
  :rationale-hash $$BLAKE3$$/intrinsics-rationale
)

; ------------------------------------------------------------
; Bytes/prepend — prepend a single byte to a Bytes substance.
;
; Signature: (byte: Bytes, rest: Bytes) → Bytes
;
; `byte` is a single-element Bytes substance (the standard
; representation of one byte). Returns a new Bytes substance
; whose payload is byte || rest.payload.
; ------------------------------------------------------------

(form
  :type-tag      "Form/v1"
  :name          "Bytes_prepend"
  :declared-caps (S-03/ROOT_RO S-03/ROOT_RW)
  :declared-traps (ETYPE)
  :arity         2
  :locals-n      4
  :code (
    STORE   0                       ; rest Bytes hash
    STORE   1                       ; byte (single-byte Bytes hash)
    ; read byte payload
    LOAD    1
    READ
    PUSH    16
    PUSH    1
    PUSH    "Schema/bytes_in_range"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=3
    STORE   2                       ; the single raw byte as Bytes payload
    ; read rest payload
    LOAD    0
    READ
    STORE   3
    LOAD    3
    PUSH    8
    PUSH    8
    PUSH    "Schema/bytes_in_range"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=3
    PUSH    "Bytes/to_nat_be"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=1                ; rest_len
    PUSH    1
    ADD                             ; new_len = 1 + rest_len
    LOAD    2                       ; byte payload
    LOAD    3
    PUSH    16
    PUSH    "Bytes/len"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=1                ; rest raw payload len
    PUSH    "Schema/bytes_in_range"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=3                ; rest raw payload bytes
    MAKEPAIR
    SEAL    "Bytes/v1"              ; new Bytes substance
    RET
  )
  :rationale-hash $$BLAKE3$$/intrinsics-rationale
)

; ============================================================
; Group B: Nat/* intrinsics
; ============================================================

; ------------------------------------------------------------
; Nat/mul — multiply two Nats.
;
; Signature: (a: Nat, b: Nat) → Nat
;
; The IL has ADD and SUB but no MUL opcode. We implement
; multiplication by repeated addition via a tail-recursive
; accumulator. For the parser's practical inputs (small Nats
; like byte counts and digit values) this is fast enough.
;
; Delegates to Nat/mul_rec(a, b, acc=0).
; ------------------------------------------------------------

(form
  :type-tag      "Form/v1"
  :name          "Nat_mul"
  :declared-caps ()
  :declared-traps ()
  :arity         2
  :locals-n      2
  :code (
    STORE   0                       ; b
    STORE   1                       ; a
    LOAD    1
    LOAD    0
    PUSH    0                       ; initial accumulator
    PUSH    "Nat/mul_rec"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=3
    RET
  )
  :rationale-hash $$BLAKE3$$/intrinsics-rationale
)

; ------------------------------------------------------------
; Nat/mul_rec — tail-recursive inner loop for Nat/mul.
;
; Signature: (a: Nat, b: Nat, acc: Nat) → Nat
;
; Base case: b == 0 → return acc.
; Step: recurse(a, b-1, acc+a).
; ------------------------------------------------------------

(form
  :type-tag      "Form/v1"
  :name          "Nat_mul_rec"
  :declared-caps ()
  :declared-traps ()
  :arity         3
  :locals-n      3
  :code (
    STORE   0                       ; acc
    STORE   1                       ; b
    STORE   2                       ; a
    LOAD    1
    PUSH    0
    EQ
    JMPZ    +not_done
    LOAD    0
    RET
    :not_done
    LOAD    2
    LOAD    1
    PUSH    1
    SUB
    LOAD    0
    LOAD    2
    ADD
    PUSH    "Nat/mul_rec"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=3
    RET
  )
  :rationale-hash $$BLAKE3$$/intrinsics-rationale
)

; ============================================================
; Group C: Vec/* intrinsics
; ============================================================

; ------------------------------------------------------------
; Vec/len — return the length of a Vec substance.
;
; Layout from kernel/types/SCHEMA.md:
;   offset 0 : type_tag ("Vec/v1", 6 bytes)
;   offset 6 : n        (Nat, 4 bytes)
;   offset 10: elements
;
; Reads the substance, verifies the type tag, returns n.
; ------------------------------------------------------------

(form
  :type-tag      "Form/v1"
  :name          "Vec_len"
  :declared-caps (S-03/ROOT_RO)
  :declared-traps (ETYPE)
  :arity         1
  :locals-n      2
  :code (
    STORE   0
    LOAD    0
    READ
    STORE   1
    LOAD    1
    PUSH    0
    PUSH    6
    PUSH    "Schema/bytes_in_range"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=3
    PUSH    "Vec/v1"
    EQ
    JMPZ    +type_ok
    TRAP    ETYPE
    :type_ok
    LOAD    1
    PUSH    6
    PUSH    4
    PUSH    "Schema/bytes_in_range"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=3                ; → 4-byte Nat field
    PUSH    "Bytes/to_nat_be"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=1
    RET
  )
  :rationale-hash $$BLAKE3$$/intrinsics-rationale
)

; ------------------------------------------------------------
; Vec/index — return element at position i of a Vec substance.
;
; Signature: (vec: Vec, i: Nat) → Hash
;
; Vec elements are Hashes (32 bytes each) at offset 10 + i*32.
; Traps ETYPE if i >= Vec/len(vec).
; ------------------------------------------------------------

(form
  :type-tag      "Form/v1"
  :name          "Vec_index"
  :declared-caps (S-03/ROOT_RO)
  :declared-traps (ETYPE)
  :arity         2
  :locals-n      4
  :code (
    STORE   0                       ; i
    STORE   1                       ; vec hash
    LOAD    1
    PUSH    "Vec/len"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=1
    STORE   2                       ; len
    LOAD    0
    LOAD    2
    LT
    JMPZ    +in_bounds
    TRAP    ETYPE                   ; i >= len
    :in_bounds
    LOAD    1
    READ
    STORE   3                       ; raw bytes
    LOAD    3
    LOAD    0
    PUSH    32
    PUSH    "Nat/mul"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=2                ; i * 32
    PUSH    10
    ADD                             ; offset = 10 + i*32
    PUSH    32
    PUSH    "Schema/bytes_in_range"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=3                ; → 32-byte element (a Hash)
    RET
  )
  :rationale-hash $$BLAKE3$$/intrinsics-rationale
)

; ------------------------------------------------------------
; Vec/tail — return a Vec with the first element removed.
;
; Signature: (vec: Vec) → Vec
;
; Returns an empty Vec if the input has 0 elements.
; The result is a new sealed Vec substance.
; ------------------------------------------------------------

(form
  :type-tag      "Form/v1"
  :name          "Vec_tail"
  :declared-caps (S-03/ROOT_RO S-03/ROOT_RW)
  :declared-traps (ETYPE)
  :arity         1
  :locals-n      3
  :code (
    STORE   0
    LOAD    0
    PUSH    "Vec/len"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=1
    STORE   1                       ; len
    LOAD    1
    PUSH    0
    EQ
    JMPZ    +non_empty
    ; return empty vec
    PUSH    0
    MAKEVEC 0
    SEAL    "Vec/v1"
    RET
    :non_empty
    LOAD    0
    READ
    STORE   2                       ; raw bytes
    ; new payload = elements starting at offset 10+32 = 42, length = (len-1)*32
    LOAD    2
    PUSH    42
    LOAD    1
    PUSH    1
    SUB
    PUSH    32
    PUSH    "Nat/mul"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=2                ; (len-1)*32
    PUSH    "Schema/bytes_in_range"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=3                ; → tail element bytes
    LOAD    1
    PUSH    1
    SUB                             ; new len
    SWAP
    MAKEPAIR
    SEAL    "Vec/v1"
    RET
  )
  :rationale-hash $$BLAKE3$$/intrinsics-rationale
)

; ------------------------------------------------------------
; Vec/from_bytes_offset — build a Vec view of bytes from offset.
;
; Signature: (bytes: Bytes, offset: Nat) → Vec
;
; Produces a Vec/v1 substance that wraps the suffix of `bytes`
; starting at `offset`. Used by Schema/vec_from_offset to
; produce Vec views without copying the underlying data.
; ------------------------------------------------------------

(form
  :type-tag      "Form/v1"
  :name          "Vec_from_bytes_offset"
  :declared-caps (S-03/ROOT_RO S-03/ROOT_RW)
  :declared-traps (ETYPE)
  :arity         2
  :locals-n      4
  :code (
    STORE   0                       ; offset
    STORE   1                       ; bytes hash
    LOAD    1
    PUSH    "Bytes/len"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=1
    LOAD    0
    SUB                             ; suffix_len = total_len - offset
    STORE   2
    ; how many 32-byte elements fit?
    LOAD    2
    PUSH    32
    PUSH    "Nat/mul"               ; we want suffix_len / 32 — approximate via shift
    ; The IL has no DIV. We delegate to Vec/count_elems which does
    ; floored division by 32 via repeated subtraction.
    SEAL    Hash
    READSLOT
    ; Rather than implement DIV here, use the suffix bytes directly:
    ; produce a Vec whose elements are 32-byte slices of the suffix.
    ; Delegate to Vec/from_bytes_offset_rec(bytes, offset, acc=[]).
    LOAD    1
    LOAD    0
    PUSH    0
    MAKEVEC 0
    SEAL    "Vec/v1"                ; empty accumulator
    PUSH    "Vec/from_bytes_offset_rec"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=3
    RET
  )
  :rationale-hash $$BLAKE3$$/intrinsics-rationale
)

; ------------------------------------------------------------
; Vec/from_bytes_offset_rec — recursive inner loop.
;
; Signature: (bytes: Bytes, offset: Nat, acc: Vec) → Vec
;
; Reads 32 bytes at `offset`, appends to `acc`, advances by 32.
; Base case: offset + 32 > Bytes/len(bytes).
; ------------------------------------------------------------

(form
  :type-tag      "Form/v1"
  :name          "Vec_from_bytes_offset_rec"
  :declared-caps (S-03/ROOT_RO S-03/ROOT_RW)
  :declared-traps (ETYPE)
  :arity         3
  :locals-n      5
  :code (
    STORE   0                       ; acc
    STORE   1                       ; offset
    STORE   2                       ; bytes
    ; check: offset + 32 > len?
    LOAD    2
    PUSH    "Bytes/len"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=1
    STORE   3                       ; len
    LOAD    1
    PUSH    32
    ADD
    LOAD    3
    LT
    JMPZ    +has_room
    ; not enough bytes left — return acc
    LOAD    0
    RET
    :has_room
    LOAD    2
    LOAD    1
    PUSH    32
    PUSH    "Schema/bytes_in_range"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=3                ; → 32-byte element
    STORE   4
    LOAD    0
    LOAD    4
    PUSH    "Vec/append_persistent"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=2                ; acc' = append(acc, elem)
    LOAD    1
    PUSH    32
    ADD                             ; offset' = offset + 32
    SWAP
    LOAD    2
    SWAP
    PUSH    "Vec/from_bytes_offset_rec"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=3
    RET
  )
  :rationale-hash $$BLAKE3$$/intrinsics-rationale
)

; ------------------------------------------------------------
; Vec/append_persistent — append an element to a Vec substance.
;
; Signature: (vec: Vec, elem: Hash) → Vec
;
; Reads the raw bytes, appends the new 32-byte element,
; bumps the length prefix by 1, seals and returns the new Vec.
; ------------------------------------------------------------

(form
  :type-tag      "Form/v1"
  :name          "Vec_append_persistent"
  :declared-caps (S-03/ROOT_RO S-03/ROOT_RW)
  :declared-traps (ETYPE)
  :arity         2
  :locals-n      4
  :code (
    STORE   0                       ; elem hash (32 bytes)
    STORE   1                       ; vec hash
    LOAD    1
    PUSH    "Vec/len"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=1
    PUSH    1
    ADD
    STORE   2                       ; new_len = old_len + 1
    LOAD    1
    READ
    STORE   3                       ; raw bytes of old Vec
    ; read old elements block (offset 10, length = old payload)
    LOAD    3
    PUSH    10
    LOAD    2
    PUSH    1
    SUB
    PUSH    32
    PUSH    "Nat/mul"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=2                ; (new_len-1)*32 = old element bytes length
    PUSH    "Schema/bytes_in_range"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=3                ; old elements as raw bytes
    LOAD    0                       ; new elem (a 32-byte hash)
    MAKEPAIR                        ; Pair{old_elems, new_elem_hash}
    ; seal new Vec
    LOAD    2                       ; new_len
    SWAP
    MAKEPAIR                        ; Pair{new_len, Pair{old_elems, new_elem}}
    SEAL    "Vec/v1"
    RET
  )
  :rationale-hash $$BLAKE3$$/intrinsics-rationale
)

; ============================================================
; Group D: Parser/* deepest recursion helpers
; ============================================================

; ------------------------------------------------------------
; Parser/cursor_byte — return the current byte at the cursor.
;
; Signature: (cursor: Cursor) → Bytes (single byte)
;
; A Cursor is Pair{Bytes, Nat} sealed as a Cursor/v1 substance.
; This helper reads the cursor's byte array and offset, then
; delegates to Parser/byte_at.
; ------------------------------------------------------------

(form
  :type-tag      "Form/v1"
  :name          "Parser_cursor_byte"
  :declared-caps (S-03/ROOT_RO)
  :declared-traps (ETYPE)
  :arity         1
  :locals-n      3
  :code (
    STORE   0
    LOAD    0
    PUSH    "Parser/cursor_bytes"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=1
    STORE   1
    LOAD    0
    PUSH    "Parser/cursor_offset"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=1
    STORE   2
    LOAD    1
    LOAD    2
    PUSH    "Parser/byte_at"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=2
    RET
  )
  :rationale-hash $$BLAKE3$$/intrinsics-rationale
)

; ------------------------------------------------------------
; Parser/scan_class_run_rec — recursive character-class scanner.
;
; Signature: (cursor: Cursor, class_tag: Bytes) → Pair{Cursor, Bytes}
;
; Advances the cursor as long as the current byte belongs to
; the named class. Returns Pair{new_cursor, matched_bytes}.
;
; Class membership is decided by Parser/byte_in_class, a
; constant-table lookup keyed on class_tag (e.g. "digit",
; "ident", "hash_token"). The result is accumulated via
; Bytes/prepend in reverse then reversed at the end.
; ------------------------------------------------------------

(form
  :type-tag      "Form/v1"
  :name          "Parser_scan_class_run_rec"
  :declared-caps (S-03/ROOT_RO)
  :declared-traps (ETYPE)
  :arity         2
  :locals-n      5
  :code (
    STORE   0                       ; class_tag
    STORE   1                       ; cursor
    ; check if current byte is at end (offset >= len)
    LOAD    1
    PUSH    "Parser/cursor_bytes"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=1
    PUSH    "Bytes/len"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=1
    STORE   2                       ; total_len
    LOAD    1
    PUSH    "Parser/cursor_offset"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=1
    STORE   3                       ; current offset
    LOAD    3
    LOAD    2
    LT
    JMPZ    +at_end                 ; offset < len means we have bytes
    ; at end — return cursor + empty bytes
    LOAD    1
    PUSH    0
    MAKEVEC 0
    SEAL    "Bytes/v1"
    MAKEPAIR
    RET
    :at_end
    ; check class membership
    LOAD    1
    PUSH    "Parser/cursor_byte"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=1
    STORE   4                       ; current byte
    LOAD    4
    LOAD    0
    PUSH    "Parser/byte_in_class"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=2
    JMPZ    +not_member
    ; byte matches — advance and recurse
    LOAD    1
    PUSH    1
    PUSH    "Parser/cursor_advance"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=2
    LOAD    0
    PUSH    "Parser/scan_class_run_rec"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=2                ; → Pair{cursor', rest_bytes}
    STORE   2
    LOAD    2
    FST
    LOAD    4
    LOAD    2
    SND
    PUSH    "Bytes/prepend"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=2                ; prepend current byte → new_bytes
    MAKEPAIR
    RET
    :not_member
    ; byte doesn't match — return cursor + empty bytes
    LOAD    1
    PUSH    0
    MAKEVEC 0
    SEAL    "Bytes/v1"
    MAKEPAIR
    RET
  )
  :rationale-hash $$BLAKE3$$/intrinsics-rationale
)

; ------------------------------------------------------------
; Parser/byte_in_class — is a byte a member of the named class?
;
; Signature: (byte: Bytes, class_tag: Bytes) → Bool
;
; Dispatches on class_tag:
;   "digit"      → 0x30..0x39
;   "ident"      → 0x30..0x39, 0x41..0x5A, 0x61..0x7A, '-', '_', '/'
;   "hash_token" → 0x30..0x39, 0x41..0x46, 0x61..0x66, '$'
; Uses byte comparison chains. In a future version this could
; be a table; for now it is explicit range tests.
; ------------------------------------------------------------

(form
  :type-tag      "Form/v1"
  :name          "Parser_byte_in_class"
  :declared-caps (S-03/ROOT_RO)
  :declared-traps (ETYPE)
  :arity         2
  :locals-n      3
  :code (
    STORE   0                       ; class_tag
    STORE   1                       ; byte (single-byte Bytes)
    LOAD    1
    PUSH    "Bytes/to_nat_be"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=1
    STORE   2                       ; byte as Nat
    LOAD    0
    PUSH    "digit"
    EQ
    JMPZ    +not_digit_class
    LOAD    2
    PUSH    0x30
    LT                              ; byte < '0'?
    JMPZ    +digit_low_ok
    PUSH    false
    RET
    :digit_low_ok
    LOAD    2
    PUSH    0x39
    LT
    JMPZ    +digit_high_ok
    PUSH    true
    RET
    :digit_high_ok
    LOAD    2
    PUSH    0x39
    EQ
    RET
    :not_digit_class
    LOAD    0
    PUSH    "hash_token"
    EQ
    JMPZ    +not_hash_class
    ; hex digit or '$'
    LOAD    2
    PUSH    0x24                    ; '$'
    EQ
    JMPZ    +not_dollar
    PUSH    true
    RET
    :not_dollar
    LOAD    2
    PUSH    0x30
    LT
    JMPZ    +ht_low_ok
    PUSH    false
    RET
    :ht_low_ok
    LOAD    2
    PUSH    0x39
    LT
    JMPZ    +ht_is_digit
    PUSH    true
    RET
    :ht_is_digit
    LOAD    2
    PUSH    0x39
    EQ
    JMPZ    +ht_not_09
    PUSH    true
    RET
    :ht_not_09
    LOAD    2
    PUSH    0x41
    LT
    JMPZ    +ht_upper_ok
    PUSH    false
    RET
    :ht_upper_ok
    LOAD    2
    PUSH    0x46
    LT
    JMPZ    +ht_is_upper
    PUSH    true
    RET
    :ht_is_upper
    LOAD    2
    PUSH    0x46
    EQ
    JMPZ    +ht_not_upper
    PUSH    true
    RET
    :ht_not_upper
    LOAD    2
    PUSH    0x61
    LT
    JMPZ    +ht_lower_ok
    PUSH    false
    RET
    :ht_lower_ok
    LOAD    2
    PUSH    0x66
    LT
    JMPZ    +ht_is_lower
    PUSH    true
    RET
    :ht_is_lower
    LOAD    2
    PUSH    0x66
    EQ
    RET
    :not_hash_class
    ; default: ident class — alpha, digit, '-', '_', '/'
    LOAD    2
    PUSH    0x2D
    EQ
    JMPZ    +not_dash
    PUSH    true
    RET
    :not_dash
    LOAD    2
    PUSH    0x2F
    EQ
    JMPZ    +not_slash
    PUSH    true
    RET
    :not_slash
    LOAD    2
    PUSH    0x5F
    EQ
    JMPZ    +not_underscore
    PUSH    true
    RET
    :not_underscore
    LOAD    2
    PUSH    0x30
    LT
    JMPZ    +id_low_ok
    PUSH    false
    RET
    :id_low_ok
    LOAD    2
    PUSH    0x39
    LT
    JMPZ    +id_is_digit
    PUSH    true
    RET
    :id_is_digit
    LOAD    2
    PUSH    0x39
    EQ
    JMPZ    +id_not_digit
    PUSH    true
    RET
    :id_not_digit
    LOAD    2
    PUSH    0x41
    LT
    JMPZ    +id_upper_start
    PUSH    false
    RET
    :id_upper_start
    LOAD    2
    PUSH    0x5A
    LT
    JMPZ    +id_in_upper
    PUSH    true
    RET
    :id_in_upper
    LOAD    2
    PUSH    0x5A
    EQ
    JMPZ    +id_not_upper
    PUSH    true
    RET
    :id_not_upper
    LOAD    2
    PUSH    0x61
    LT
    JMPZ    +id_lower_start
    PUSH    false
    RET
    :id_lower_start
    LOAD    2
    PUSH    0x7A
    LT
    JMPZ    +id_in_lower
    PUSH    true
    RET
    :id_in_lower
    LOAD    2
    PUSH    0x7A
    EQ
    RET
  )
  :rationale-hash $$BLAKE3$$/intrinsics-rationale
)

; ------------------------------------------------------------
; Parser/fold_digits_acc — accumulator loop for digit→Nat.
;
; Signature: (digits: Bytes, acc: Nat) → Nat
;
; Base case: Bytes/len(digits) == 0 → return acc.
; Step: read first byte, convert to digit value (byte - 0x30),
; new_acc = acc * 10 + digit_val, recurse on tail.
; ------------------------------------------------------------

(form
  :type-tag      "Form/v1"
  :name          "Parser_fold_digits_acc"
  :declared-caps (S-03/ROOT_RO)
  :declared-traps (ETYPE)
  :arity         2
  :locals-n      4
  :code (
    STORE   0                       ; acc
    STORE   1                       ; digits Bytes
    LOAD    1
    PUSH    "Bytes/len"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=1
    PUSH    0
    EQ
    JMPZ    +not_empty
    LOAD    0
    RET
    :not_empty
    LOAD    1
    PUSH    0
    PUSH    1
    PUSH    "Schema/bytes_in_range"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=3                ; → first byte as Bytes
    PUSH    "Bytes/to_nat_be"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=1
    PUSH    0x30
    SUB                             ; digit value 0..9
    STORE   2
    LOAD    0
    PUSH    10
    PUSH    "Nat/mul"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=2
    LOAD    2
    ADD
    STORE   3                       ; new_acc
    LOAD    1
    PUSH    1
    PUSH    "Bytes/len"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=1
    PUSH    1
    SUB
    PUSH    "Bytes/slice"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=3               ; tail bytes (skip first)
    LOAD    3
    PUSH    "Parser/fold_digits_acc"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=2
    RET
  )
  :rationale-hash $$BLAKE3$$/intrinsics-rationale
)

; ------------------------------------------------------------
; Parser/resolve_sentinel — look up a $$BLAKE3$$ sentinel in
; the manifest immediates table.
;
; Signature: (sentinel_bytes: Bytes) → Hash
;
; The sentinel bytes are the raw token text (e.g. the bytes of
; "$$BLAKE3$$/some-rationale"). This helper calls READSLOT on
; the sentinel's interned hash to return the resolved Hash.
;
; If the slot is unbound (manifest not yet built), returns
; BOTTOM_HASH as a placeholder. At v0.5.0-build time, every
; slot must be bound before ignition.
; ------------------------------------------------------------

(form
  :type-tag      "Form/v1"
  :name          "Parser_resolve_sentinel"
  :declared-caps (S-03/ROOT_RO)
  :declared-traps ()
  :arity         1
  :locals-n      1
  :code (
    STORE   0                       ; sentinel bytes
    LOAD    0
    SEAL    "SentinelKey/v1"        ; intern the sentinel text as a substance key
    READSLOT                        ; → Hash or BOTTOM_HASH if unbound
    RET
  )
  :rationale-hash $$BLAKE3$$/intrinsics-rationale
)

; ------------------------------------------------------------
; Parser/hex_to_hash — convert a 64-char hex string to a Hash.
;
; Signature: (hex_bytes: Bytes) → Hash
;
; Expects exactly 64 ASCII hex digit bytes. Converts pairs of
; nibbles to bytes via repeated shifts and folds, producing a
; 32-byte Hash. Delegates to Parser/hex_to_hash_rec.
; ------------------------------------------------------------

(form
  :type-tag      "Form/v1"
  :name          "Parser_hex_to_hash"
  :declared-caps (S-03/ROOT_RO)
  :declared-traps (ETYPE)
  :arity         1
  :locals-n      1
  :code (
    STORE   0
    LOAD    0
    PUSH    "Bytes/len"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=1
    PUSH    64
    EQ
    JMPZ    +len_ok
    TRAP    ETYPE
    :len_ok
    LOAD    0
    PUSH    0
    PUSH    0
    MAKEVEC 0
    SEAL    "Bytes/v1"              ; empty acc
    PUSH    "Parser/hex_to_hash_rec"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=3
    RET
  )
  :rationale-hash $$BLAKE3$$/intrinsics-rationale
)

; ------------------------------------------------------------
; Parser/hex_to_hash_rec — recursive hex decoder.
;
; Signature: (hex_bytes: Bytes, idx: Nat, acc: Bytes) → Hash
;
; Base case: idx == 64 → return acc sealed as Hash.
; Step: read nibble pair at idx and idx+1, convert to byte,
; append to acc, recurse with idx+2.
; ------------------------------------------------------------

(form
  :type-tag      "Form/v1"
  :name          "Parser_hex_to_hash_rec"
  :declared-caps (S-03/ROOT_RO S-03/ROOT_RW)
  :declared-traps (ETYPE)
  :arity         3
  :locals-n      6
  :code (
    STORE   0                       ; acc
    STORE   1                       ; idx
    STORE   2                       ; hex_bytes
    LOAD    1
    PUSH    64
    EQ
    JMPZ    +not_done
    LOAD    0
    SEAL    Hash                    ; → Hash from 32-byte Bytes
    RET
    :not_done
    ; read high nibble
    LOAD    2
    LOAD    1
    PUSH    1
    PUSH    "Schema/bytes_in_range"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=3
    PUSH    "Bytes/to_nat_be"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=1
    PUSH    "Parser/hex_nibble_val"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=1
    STORE   3                       ; high nibble value
    ; read low nibble
    LOAD    2
    LOAD    1
    PUSH    1
    ADD
    PUSH    1
    PUSH    "Schema/bytes_in_range"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=3
    PUSH    "Bytes/to_nat_be"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=1
    PUSH    "Parser/hex_nibble_val"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=1
    STORE   4                       ; low nibble value
    ; byte = high * 16 + low
    LOAD    3
    PUSH    16
    PUSH    "Nat/mul"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=2
    LOAD    4
    ADD
    STORE   5                       ; byte value as Nat
    ; pack into single-byte Bytes
    LOAD    5
    SEAL    "Byte/v1"               ; byte as typed substance
    LOAD    0
    SWAP
    PUSH    "Bytes/prepend"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=2                ; prepend to acc — result is reversed
    STORE   0
    LOAD    2
    LOAD    1
    PUSH    2
    ADD
    LOAD    0
    PUSH    "Parser/hex_to_hash_rec"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=3
    RET
  )
  :rationale-hash $$BLAKE3$$/intrinsics-rationale
)

; ------------------------------------------------------------
; Parser/hex_nibble_val — ASCII hex char to nibble 0..15.
;
; Signature: (char_nat: Nat) → Nat
;
; Traps ETYPE if the character is not a valid hex digit.
; ------------------------------------------------------------

(form
  :type-tag      "Form/v1"
  :name          "Parser_hex_nibble_val"
  :declared-caps ()
  :declared-traps (ETYPE)
  :arity         1
  :locals-n      1
  :code (
    STORE   0
    ; '0'..'9'
    LOAD    0
    PUSH    0x30
    LT
    JMPZ    +above_0
    TRAP    ETYPE
    :above_0
    LOAD    0
    PUSH    0x39
    LT
    JMPZ    +is_digit
    PUSH    true
    JMPZ    +check_upper
    :is_digit
    LOAD    0
    PUSH    0x39
    EQ
    JMPZ    +digit_done
    PUSH    true
    :digit_done
    JMPZ    +do_digit
    PUSH    false
    RET
    :do_digit
    LOAD    0
    PUSH    0x30
    SUB
    RET
    :check_upper
    ; 'A'..'F'
    LOAD    0
    PUSH    0x41
    LT
    JMPZ    +above_A
    TRAP    ETYPE
    :above_A
    LOAD    0
    PUSH    0x46
    LT
    JMPZ    +is_upper
    PUSH    true
    JMPZ    +check_lower
    :is_upper
    LOAD    0
    PUSH    0x46
    EQ
    JMPZ    +upper_done
    PUSH    true
    :upper_done
    JMPZ    +do_upper
    PUSH    false
    RET
    :do_upper
    LOAD    0
    PUSH    0x41
    SUB
    PUSH    10
    ADD
    RET
    :check_lower
    ; 'a'..'f'
    LOAD    0
    PUSH    0x61
    LT
    JMPZ    +above_a
    TRAP    ETYPE
    :above_a
    LOAD    0
    PUSH    0x66
    LT
    JMPZ    +is_lower
    PUSH    true
    JMPZ    +bad
    :is_lower
    LOAD    0
    PUSH    0x66
    EQ
    JMPZ    +lower_done
    PUSH    true
    :lower_done
    JMPZ    +do_lower
    :bad
    TRAP    ETYPE
    :do_lower
    LOAD    0
    PUSH    0x61
    SUB
    PUSH    10
    ADD
    RET
  )
  :rationale-hash $$BLAKE3$$/intrinsics-rationale
)

; ------------------------------------------------------------
; Parser/table_lookup — linear scan over a Vec looking for a key.
;
; Signature: (key: Hash, table: Vec{Pair{Hash, T}}) → T
;
; Iterates entries of `table`; each entry is Pair{key_hash, value}.
; Returns the value for the first matching key.
; Returns BOTTOM_HASH if not found.
; Delegates to Parser/table_lookup_rec.
; ------------------------------------------------------------

(form
  :type-tag      "Form/v1"
  :name          "Parser_table_lookup"
  :declared-caps (S-03/ROOT_RO)
  :declared-traps (ETYPE)
  :arity         2
  :locals-n      2
  :code (
    STORE   0                       ; table Vec hash
    STORE   1                       ; key Hash
    LOAD    1
    LOAD    0
    PUSH    0
    PUSH    "Parser/table_lookup_rec"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=3
    RET
  )
  :rationale-hash $$BLAKE3$$/intrinsics-rationale
)

; ------------------------------------------------------------
; Parser/table_lookup_rec — recursive inner loop for table_lookup.
;
; Signature: (key: Hash, table: Vec, idx: Nat) → T
; ------------------------------------------------------------

(form
  :type-tag      "Form/v1"
  :name          "Parser_table_lookup_rec"
  :declared-caps (S-03/ROOT_RO)
  :declared-traps (ETYPE)
  :arity         3
  :locals-n      5
  :code (
    STORE   0                       ; idx
    STORE   1                       ; table
    STORE   2                       ; key
    LOAD    1
    PUSH    "Vec/len"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=1
    LOAD    0
    EQ
    JMPZ    +not_empty
    PUSH    BOTTOM_HASH
    RET
    :not_empty
    LOAD    1
    LOAD    0
    PUSH    "Vec/index"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=2
    READ                            ; → Pair{key_hash, value}
    STORE   3
    LOAD    3
    FST
    LOAD    2
    EQ
    JMPZ    +no_match
    LOAD    3
    SND
    RET
    :no_match
    LOAD    2
    LOAD    1
    LOAD    0
    PUSH    1
    ADD
    PUSH    "Parser/table_lookup_rec"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=3
    RET
  )
  :rationale-hash $$BLAKE3$$/intrinsics-rationale
)

; ------------------------------------------------------------
; Parser/trapkind_enumeration — validate an identifier against
; the closed TrapKind enumeration from IL.md § Trap kinds.
;
; Signature: (ident_bytes: Bytes) → TrapKind
;
; Returns a sealed TrapKind substance if the ident matches one
; of the 11 defined kinds. Traps ETYPE on unrecognised input.
;
; The check is a chain of EQ tests on the raw Bytes. This is
; verbose but complete and amenable to structural reading.
; ------------------------------------------------------------

(form
  :type-tag      "Form/v1"
  :name          "Parser_trapkind_enumeration"
  :declared-caps (S-03/ROOT_RO S-03/ROOT_RW)
  :declared-traps (ETYPE)
  :arity         1
  :locals-n      1
  :code (
    STORE   0
    LOAD    0
    PUSH    "EBADLOCAL"
    EQ
    JMPZ    +not_ebadlocal
    LOAD    0
    SEAL    "TrapKind/v1"
    RET
    :not_ebadlocal
    LOAD    0
    PUSH    "ETYPE"
    EQ
    JMPZ    +not_etype
    LOAD    0
    SEAL    "TrapKind/v1"
    RET
    :not_etype
    LOAD    0
    PUSH    "EUNDERFLOW"
    EQ
    JMPZ    +not_eunderflow
    LOAD    0
    SEAL    "TrapKind/v1"
    RET
    :not_eunderflow
    LOAD    0
    PUSH    "EUNHELD"
    EQ
    JMPZ    +not_eunheld
    LOAD    0
    SEAL    "TrapKind/v1"
    RET
    :not_eunheld
    LOAD    0
    PUSH    "ENOTHELD"
    EQ
    JMPZ    +not_enotheld
    LOAD    0
    SEAL    "TrapKind/v1"
    RET
    :not_enotheld
    LOAD    0
    PUSH    "ESTALE"
    EQ
    JMPZ    +not_estale
    LOAD    0
    SEAL    "TrapKind/v1"
    RET
    :not_estale
    LOAD    0
    PUSH    "EOVERBUDGET"
    EQ
    JMPZ    +not_eoverbudget
    LOAD    0
    SEAL    "TrapKind/v1"
    RET
    :not_eoverbudget
    LOAD    0
    PUSH    "EASSERT"
    EQ
    JMPZ    +not_eassert
    LOAD    0
    SEAL    "TrapKind/v1"
    RET
    :not_eassert
    LOAD    0
    PUSH    "EUNAUTHORISED"
    EQ
    JMPZ    +not_eunauthorised
    LOAD    0
    SEAL    "TrapKind/v1"
    RET
    :not_eunauthorised
    LOAD    0
    PUSH    "EIGNITED"
    EQ
    JMPZ    +not_eignited
    LOAD    0
    SEAL    "TrapKind/v1"
    RET
    :not_eignited
    LOAD    0
    PUSH    "EREPLAYDIVERGED"
    EQ
    JMPZ    +not_ereplaydiverged
    LOAD    0
    SEAL    "TrapKind/v1"
    RET
    :not_ereplaydiverged
    TRAP    ETYPE
  )
  :rationale-hash $$BLAKE3$$/intrinsics-rationale
)

; ------------------------------------------------------------
; OpcodeSpec/schema_offset — project the schema-id field from
; an OpcodeSpec substance.
;
; An OpcodeSpec is a `OpcodeSpec/v1` substance with layout:
;   offset 0   : type_tag ("OpcodeSpec/v1", 13 bytes)
;   offset 13  : mnemonic (Hash, 32 bytes)
;   offset 45  : schema_id (Bytes, variable — terminated by NUL)
;
; Returns the schema_id bytes. The schema_id is a short ASCII
; string like "none", "nat", "hash", "i32" that names the
; operand schema a particular opcode expects.
; ------------------------------------------------------------

(form
  :type-tag      "Form/v1"
  :name          "OpcodeSpec_schema_offset"
  :declared-caps (S-03/ROOT_RO)
  :declared-traps (ETYPE)
  :arity         1
  :locals-n      2
  :code (
    STORE   0
    LOAD    0
    READ
    STORE   1
    ; verify type tag
    LOAD    1
    PUSH    0
    PUSH    13
    PUSH    "Schema/bytes_in_range"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=3
    PUSH    "OpcodeSpec/v1"
    EQ
    JMPZ    +type_ok
    TRAP    ETYPE
    :type_ok
    ; schema_id starts at offset 45; scan until NUL (0x00)
    LOAD    1
    PUSH    45
    PUSH    0x00
    PUSH    "Parser/scan_until_byte"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=3                ; → Pair{cursor_at_nul, schema_id_bytes}
    SND
    RET
  )
  :rationale-hash $$BLAKE3$$/intrinsics-rationale
)


(exports
  (Bytes_len               (Bytes)                  → Nat)
  (Bytes_slice             (Bytes, Nat, Nat)         → Bytes)
  (Bytes_to_nat_be         (Bytes)                   → Nat)
  (Bytes_to_nat_be_rec     (Bytes, Nat, Nat)         → Nat)
  (Bytes_prepend           (Bytes, Bytes)            → Bytes)
  (Nat_mul                 (Nat, Nat)                → Nat)
  (Nat_mul_rec             (Nat, Nat, Nat)           → Nat)
  (Vec_len                 (Vec)                     → Nat)
  (Vec_index               (Vec, Nat)                → Hash)
  (Vec_tail                (Vec)                     → Vec)
  (Vec_from_bytes_offset   (Bytes, Nat)              → Vec)
  (Vec_from_bytes_offset_rec (Bytes, Nat, Vec)       → Vec)
  (Vec_append_persistent   (Vec, Hash)               → Vec)
  (Parser_cursor_byte      (Cursor)                  → Bytes)
  (Parser_scan_class_run_rec (Cursor, Bytes)         → Pair{Cursor, Bytes})
  (Parser_byte_in_class    (Bytes, Bytes)            → Bool)
  (Parser_fold_digits_acc  (Bytes, Nat)              → Nat)
  (Parser_resolve_sentinel (Bytes)                   → Hash)
  (Parser_hex_to_hash      (Bytes)                   → Hash)
  (Parser_hex_to_hash_rec  (Bytes, Nat, Bytes)       → Hash)
  (Parser_hex_nibble_val   (Nat)                     → Nat)
  (Parser_table_lookup     (Hash, Vec)               → T)
  (Parser_table_lookup_rec (Hash, Vec, Nat)          → T)
  (Parser_trapkind_enumeration (Bytes)               → TrapKind)
  (OpcodeSpec_schema_offset (OpcodeSpec)             → Bytes))

; Note: the slot names as referenced by callers use "/" separators
; (e.g. "Bytes/len", "Parser/cursor_byte") while the Form names
; in this file use "_" for the IL :name field. The READSLOT/BINDSLOT
; mechanism resolves names by sealed Hash; the human-readable :name
; is for diagnostics only. The canonical slot-name-to-hash mapping
; is in kernel/manifest.json.
