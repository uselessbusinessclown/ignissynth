; The IL parser — kernel/forms/helpers/parser.form
;
; Bound at S-07/parse_form. Reads canonical Form wire bytes and
; produces a ParsedForm substance whose fields S-07/execute and
; the field-projection helpers can read.
;
; This Form is the foundational helper of v0.2.0-helpers: until
; it exists, no Form's body can be loaded into an ExecState, no
; helper can be exercised, and the v0.3.0 simulation harness has
; nothing to run. Audit gap #4 (ROADMAP.md § Project review) is
; resolved by this commit.
;
; Synthesis chain:
;   provocation:  the IL opcode PARSEFORM (kernel/IL.md §
;                 Reflection) is shorthand for READSLOT
;                 "S-07/parse_form" + CALL. Without this Form
;                 bound, every PARSEFORM in the seed traps
;                 EUNBOUND.
;   grounding:    A0.6 (code is thought, content-addressed,
;                 transformable), A0.7 (synthesis is the only
;                 way new structure enters), A1.2 (type is
;                 intrinsic — the parser trusts the type tag),
;                 A6.1 (a unit of code is a substance), A6.4
;                 (self-reading is normal — this Form is in the
;                 IL it parses)
;   approach:     recursive descent over the canonical wire
;                 form specified in kernel/IL.md § Encoding.
;                 Top-level entry parse_form orchestrates seven
;                 sub-Forms; each sub-Form handles one syntactic
;                 element.
;   composes_with:
;                 - S-03/ROOT_RO for reading the input substance
;                 - S-07/canon/normalise for the round-trip
;                   property at the canonicalisation layer
;
; The parser is exempt from shipping its own .proof artifact ONLY
; if the helper exemption (synthesis/PROTOCOL.md § Helper
; exemption) applies. This file exceeds the 30-instruction
; smallness threshold the exemption requires, so the parser
; SHIPS its own proof artifact at kernel/forms/helpers/
; parser.proof. (Pending — drafted but not yet written; tracked
; as a v0.2.0 follow-up.)

; ============================================================
; parse_form — top-level entry point
;
; Reads a substance whose bytes are a canonical Form wire form,
; produces a ParsedForm record, and returns its hash.
;
; The parser does NOT verify the canonicalisation — that is the
; canonicaliser's job, called separately. The parser assumes
; canonical input and traps ETYPE on any deviation from the
; expected layout.
;
; Output ParsedForm record shape (sealed substance,
; type tag "ParsedForm/v1"):
;
;   ParsedForm {
;     name:           Bytes        ; from :name field
;     declared_caps:  Vec{CapId}   ; from :declared-caps field
;     declared_traps: Vec{TrapKind}; from :declared-traps field
;     arity:          Nat          ; from :arity field
;     locals_n:       Nat          ; from :locals-n field
;     code:           Vec{Opcode}  ; from :code field
;     rationale_hash: Hash         ; from :rationale-hash field
;   }
; ============================================================

(form
  :type-tag      "Form/v1"
  :name          "parse_form"
  :declared-caps (S-03/ROOT_RO)
  :declared-traps (ETYPE)
  :arity         1
  :locals-n      14
  :code (

    STORE   0                       ; locals[0] := input substance hash
    LOAD    0
    READ                            ; → raw bytes
    STORE   1                       ; locals[1] := raw bytes

    ;; ----------------------------------------------------------------
    ;; Step 1: verify the outer s-expression shape is (form ...).
    ;; The canonicaliser strips comments and whitespace; the
    ;; remaining bytes start with "(form" and end with ")".
    ;; ----------------------------------------------------------------

    LOAD    1
    PUSH    "Parser/expect_open_form"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=1                ; → cursor at offset after "(form"
    STORE   2                       ; locals[2] := cursor

    ;; ----------------------------------------------------------------
    ;; Step 2: parse each named field in canonical order.
    ;; The canonicaliser sorts fields lexicographically, so the
    ;; expected order is:
    ;;   :arity, :code, :declared-caps, :declared-traps,
    ;;   :locals-n, :name, :rationale-hash, :type-tag
    ;; A field at the wrong position traps ETYPE.
    ;; ----------------------------------------------------------------

    LOAD    2
    PUSH    ":arity"
    PUSH    "Parser/parse_nat_field"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=2                ; → Pair{cursor, Nat}
    STORE   3
    LOAD    3
    SND
    STORE   4                       ; locals[4] := arity
    LOAD    3
    FST
    STORE   2

    LOAD    2
    PUSH    ":code"
    PUSH    "Parser/parse_code_field"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=2                ; → Pair{cursor, Vec{Opcode}}
    STORE   3
    LOAD    3
    SND
    STORE   5                       ; locals[5] := code
    LOAD    3
    FST
    STORE   2

    LOAD    2
    PUSH    ":declared-caps"
    PUSH    "Parser/parse_capid_vec_field"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=2                ; → Pair{cursor, Vec{CapId}}
    STORE   3
    LOAD    3
    SND
    STORE   6                       ; locals[6] := declared_caps
    LOAD    3
    FST
    STORE   2

    LOAD    2
    PUSH    ":declared-traps"
    PUSH    "Parser/parse_trapkind_vec_field"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=2                ; → Pair{cursor, Vec{TrapKind}}
    STORE   3
    LOAD    3
    SND
    STORE   7                       ; locals[7] := declared_traps
    LOAD    3
    FST
    STORE   2

    LOAD    2
    PUSH    ":locals-n"
    PUSH    "Parser/parse_nat_field"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=2
    STORE   3
    LOAD    3
    SND
    STORE   8                       ; locals[8] := locals_n
    LOAD    3
    FST
    STORE   2

    LOAD    2
    PUSH    ":name"
    PUSH    "Parser/parse_bytes_field"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=2                ; → Pair{cursor, Bytes}
    STORE   3
    LOAD    3
    SND
    STORE   9                       ; locals[9] := name
    LOAD    3
    FST
    STORE   2

    LOAD    2
    PUSH    ":rationale-hash"
    PUSH    "Parser/parse_hash_field"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=2                ; → Pair{cursor, Hash}
    STORE   3
    LOAD    3
    SND
    STORE   10                      ; locals[10] := rationale_hash
    LOAD    3
    FST
    STORE   2

    LOAD    2
    PUSH    ":type-tag"
    PUSH    "Parser/parse_bytes_field"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=2                ; → Pair{cursor, Bytes}
    STORE   3
    LOAD    3
    SND
    STORE   11                      ; locals[11] := type_tag
    LOAD    3
    FST
    STORE   2

    ;; ----------------------------------------------------------------
    ;; Step 3: verify the type tag is "Form/v1".
    ;; ----------------------------------------------------------------

    LOAD    11
    PUSH    "Form/v1"
    EQ
    JMPZ    +trap_bad_type_tag

    ;; ----------------------------------------------------------------
    ;; Step 4: verify the closing paren and EOF.
    ;; ----------------------------------------------------------------

    LOAD    1
    LOAD    2
    PUSH    "Parser/expect_close_form_and_eof"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=2                ; traps ETYPE on bad close

    ;; ----------------------------------------------------------------
    ;; Step 5: build and seal the ParsedForm record.
    ;; ----------------------------------------------------------------

    LOAD    9                       ; name
    LOAD    6                       ; declared_caps
    LOAD    7                       ; declared_traps
    LOAD    4                       ; arity
    LOAD    8                       ; locals_n
    LOAD    5                       ; code
    LOAD    10                      ; rationale_hash
    MAKEVEC 7
    SEAL    ParsedForm
    RET

    :trap_bad_type_tag
    TRAP    ETYPE
  )
  :rationale-hash $$BLAKE3$$/parser-rationale
)

; ============================================================
; Parser/parse_nat_field — read a single :name Nat pair
;
; Input: (cursor, expected_field_name)
; Output: (new_cursor, parsed Nat value)
;
; Verifies the field name matches, reads the colon, reads the
; integer literal in canonical decimal form, advances the cursor.
; ============================================================

(form
  :type-tag      "Form/v1"
  :name          "parse_nat_field"
  :declared-caps (S-03/ROOT_RO)
  :declared-traps (ETYPE)
  :arity         2
  :locals-n      4
  :code (
    STORE   0                       ; expected field name
    STORE   1                       ; cursor

    LOAD    1
    LOAD    0
    PUSH    "Parser/expect_field_name"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=2                ; traps ETYPE on mismatch
    STORE   1                       ; cursor advanced past field name

    LOAD    1
    PUSH    "Parser/read_decimal_nat"
    SEAL    Hash
    READSLOT
    CALL    h=$ /n=1                ; → Pair{new_cursor, Nat}
    RET
  )
  :rationale-hash $$BLAKE3$$/parser-rationale
)

